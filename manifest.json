{
  "id": "architectural-review",
  "name": "ARC Requests",
  "version": "1.0.0",
  "description": "Homeowners submit modification requests for ARC committee review. Committee votes, issues decisions with written rationale, and tracks status to resolution.",
  "entrypoint": "index.html",
  "runtime": "static",
  "category": "organization",
  "tags": ["hoa", "arc", "architectural", "review", "modifications", "approval"],
  "data_access": {
    "reads": ["family.members", "family.groups"],
    "writes": []
  },
  "permissions": {
    "default_audience": "everyone",
    "requires_approval": false
  },
  "storage": "db",
  "row_policies": {
    "requests": {
      "kind": "owner_or_visibility",
      "member_column": "submitted_by",
      "visibility_column": "visibility",
      "everyone_values": ["public"],
      "bypass_group_setting": { "settings_table": "settings", "settings_key": "committee_group_id" },
      "privileged_values": ["private"],
      "write_owner_only": true
    },
    "votes": {
      "kind": "inherit_visibility",
      "fk_column": "request_id",
      "parent_table": "requests",
      "writer_column": "voter_id",
      "insert_privileged_only": true
    },
    "comments": {
      "kind": "inherit_visibility",
      "fk_column": "request_id",
      "parent_table": "requests",
      "writer_column": "author_id"
    },
    "decisions": {
      "kind": "inherit_visibility",
      "fk_column": "request_id",
      "parent_table": "requests",
      "writer_column": "decided_by",
      "insert_privileged_only": true
    },
    "settings": {
      "kind": "app_config"
    }
  },
  "admin_config": {
    "settings_table": "settings",
    "keys": ["committee_group_id", "default_visibility"]
  },
  "file_acls": {
    "write": { "require_role": "adult" }
  },
  "document_acls": {
    "write": { "require_role": "adult" }
  },
  "nav": {
    "label": "ARC Requests"
  },
  "resource_limits": {
    "max_db_bytes": 209715200,
    "max_files_bytes": 524288000,
    "max_docs_bytes": 524288000
  },
  "icon": "🏛️",
  "ai_access": {
    "allowed": true,
    "mode": "read",
    "db_exports": ["open_requests", "all_requests"]
  }
}
